{
    "name": "triton-ts",
    "version": "1.0.1",
    "type": "module",
    "license": "MIT",
    "description": "Nvidia Triton server gRPC client for TypeScript",
    "homepage": "https://github.com/MrExplode/triton-ts",
    "repository": "https://github.com/MrExplode/triton-ts.git",
    "bugs": "https://github.com/MrExplode/triton-ts/issues",
    "author": "SunStorm <me@sunstorm.rocks> (https://sunstorm.rocks)",
    "main": "./dist/main.cjs",
    "module": "./dist/main.js",
    "types": "./dist/main.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/main.d.ts",
                "default": "./dist/main.js"
            },
            "default": {
                "types": "./dist/main.d.cts",
                "default": "./dist/main.cjs"
            }
        }
    },
    "scripts": {
        "build-fast": "tsup",
        "build": "tsup --dts-resolve",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@bufbuild/buf": "^1.70.0",
        "@bufbuild/protoc-gen-es": "^2.12.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "tsup": "^8.5.1",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.61.0"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.12.0"
    },
    "engines": {
        "node": ">= 24.16.0"
    }
}
